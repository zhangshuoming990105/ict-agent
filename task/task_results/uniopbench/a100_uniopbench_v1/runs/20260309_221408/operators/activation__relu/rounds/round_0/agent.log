def __getattr__(name: str):
    """Lazy import for variant and suite modules to avoid circular imports."""
    if name == "VariantSpec":
        from .variant import VariantSpec

        return VariantSpec
    if name == "VariantGenerator":
        from .variant import VariantGenerator

        return VariantGenerator
    if name == "SuiteResult":
        from .suite import SuiteResult

        return SuiteResult
    if name == "TestSuite":
        from .suite import TestSuite

        return TestSuite
    if name == "create_suite":
        from .suite import create_suite

        return create_suite
    if name == "create_suite_from_list":
        from .suite import create_suite_from_list

        return create_suite_from_list
    raise AttributeError(f"module {__name__!r} has no attribute {name!r}")
