  25|// Parallel NMS kernel using CUDA streams
  26|__global__ void nms_kernel_parallel(const float* boxes, int* keep, int num_boxes, 
  27|                                     float iou_threshold, int ref_idx) {
  28|    int idx = blockIdx.x * blockDim.x + threadIdx.x + ref_idx + 1;
  29|    
  30|    if (idx >= num_boxes) return;
  31|    
  32|    // If current box is already suppressed, skip
  33|    if (keep[idx] == 0) return;
  34|    
  35|    // If reference box is suppressed, skip
  36|    if (keep[ref_idx] == 0) return;
  37|    
  38|    // Load boxes using vectorized loads
  39|    const float4* boxes4 = reinterpret_cast<const float4*>(boxes);
  40|    float4 ref_box = boxes4[ref_idx];
  41|    float4 current_box = boxes4[idx];
  42|    
  43|    float iou = compute_iou(ref_box, current_box);
  44|    
  45|    // Suppress if IoU exceeds threshold
  46|    if (iou > iou_threshold) {
  47|        keep[idx] = 0;
  48|    }
