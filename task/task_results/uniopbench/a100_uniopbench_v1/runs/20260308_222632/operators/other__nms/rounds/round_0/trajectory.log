  52|    const int threads_per_block = 256;
  53|    const int streams_count = 8;
  54|    
  55|    // Create streams for concurrent kernel execution
  56|    cudaStream_t streams[streams_count];
  57|    for (int i = 0; i < streams_count; i++) {
  58|        cudaStreamCreate(&streams[i]);
  59|    }
