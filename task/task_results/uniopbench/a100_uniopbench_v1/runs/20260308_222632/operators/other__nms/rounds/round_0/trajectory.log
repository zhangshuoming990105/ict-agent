  4|// Compute IoU between two boxes
  5|// Box format: [x1, y1, x2, y2]
  6|__device__ __forceinline__ float compute_iou(const float4& box1, const float4& box2) {
  7|    // Intersection area
  8|    float inter_x1 = fmaxf(box1.x, box2.x);
  9|    float inter_y1 = fmaxf(box1.y, box2.y);
  10|    float inter_x2 = fminf(box1.z, box2.z);
  11|    float inter_y2 = fminf(box1.w, box2.w);
  12|    
  13|    float inter_w = fmaxf(0.0f, inter_x2 - inter_x1);
  14|    float inter_h = fmaxf(0.0f, inter_y2 - inter_y1);
  15|    float inter_area = inter_w * inter_h;
  16|    
  17|    // Union area
  18|    float area1 = (box1.z - box1.x) * (box1.w - box1.y);
  19|    float area2 = (box2.z - box2.x) * (box2.w - box2.y);
  20|    float union_area = area1 + area2 - inter_area;
  21|    
  22|    return (union_area > 0.0f) ? (inter_area / union_area) : 0.0f;
  23|}
