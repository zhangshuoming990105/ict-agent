command=python3 << 'EOF'
import torch
import sys
import ctypes
sys.path.insert(0, '.')

# Manually test FP16
torch.manual_seed(42)
device = 'cuda'
dtype = torch.float16

# Create small test case
shape = (2, 2, 2, 2)  # batch=2, channels=2, h=2, w=2
batch_size = 2
num_channels = 2
spatial_size = 4

x = torch.randn(shape, dtype=dtype, device=device)
running_mean = torch.randn(num_channels, dtype=dtype, device=device)
running_var = torch.rand(num_channels, dtype=dtype, device=device) + 0.5
gamma = torch.randn(num_channels, dtype=dtype, device=device)
beta = torch.randn(num_channels, dtype=dtype, device=device)
output = torch.empty_like(x)

# PyTorch reference
import torch.nn.functional as F
torch_output = F.batch_norm(x, running_mean, running_var, weight=gamma, bias=beta, training=False, momentum=0.0, eps=1e-5)

# Load CUDA kernel
lib = ctypes.CDLL('./cuda_/lib_cuda_kernel.so')
lib.cuda_kernel.argtypes = [
    ctypes.c_void_p, ctypes.c_void_p, ctypes.c_void_p,
    ctypes.c_void_p, ctypes.c_void_p, ctypes.c_void_p,
    ctypes.c_int, ctypes.c_int, ctypes.c_int
]

# Call kernel
lib.cuda_kernel(
    x.data_ptr(), output.data_ptr(),
    running_mean.data_ptr(), running_var.data_ptr(),
    gamma.data_ptr(), beta.data_ptr(),
    batch_size, num_channels, spatial_size
)
torch.cuda.synchronize()

# Compare
print("PyTorch output (FP16):")
print(torch_output.cpu().float()[:, 0, 0, :])
print("\nCUDA output (FP16):")
print(output.cpu().float()[:, 0, 0, :])
print("\nMax abs error:", (torch_output - output).abs().max().item())
print("Mean abs error:", (torch_output - output).abs().mean().item())
