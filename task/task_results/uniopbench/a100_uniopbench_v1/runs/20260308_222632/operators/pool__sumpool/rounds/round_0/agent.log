command=python3 -c "
import torch
import ctypes
import sys
sys.path.insert(0, '.')
from optest.tools.builder import load_cuda_kernel

# Load kernel
kernel_fn = load_cuda_kernel('.', 'cuda_kernel', [
    ctypes.c_void_p,  # input
    ctypes.c_void_p,  # output
    ctypes.c_int,  # batch_size
    ctypes.c_int,  # channels
    ctypes.c_int,  # input_H
    ctypes.c_int,  # kernel_size
    ctypes.c_int,  # stride
])

# Test with small data
batch, H, W, C = 2, 8, 8, 4
kernel_size, stride = 3, 1
out_H = (H - kernel_size) // stride + 1  # = 6
out_W = (W - kernel_size) // stride + 1  # = 6

print(f'Input NHWC: ({batch}, {H}, {W}, {C})')
print(f'Output NHWC should be: ({batch}, {out_H}, {out_W}, {C})')

x = torch.ones(batch, H, W, C, device='cuda', dtype=torch.float32)
out = torch.zeros(batch, out_H, out_W, C, device='cuda', dtype=torch.float32)

print(f'Output tensor shape: {out.shape}')
print(f'Output tensor size: {out.numel()}')

kernel_fn(
    ctypes.c_void_p(x.data_ptr()),
    ctypes.c_void_p(out.data_ptr()),
    batch,
    C,
    H,
    kernel_size,
    stride
)

torch.cuda.synchronize()
print(f'Output after kernel: {out.shape}')
print(f'Expected value (sum of 3x3=9 ones): 9.0')
print(f'Actual output[0,0,0,:]: {out[0,0,0,:]}')
"
