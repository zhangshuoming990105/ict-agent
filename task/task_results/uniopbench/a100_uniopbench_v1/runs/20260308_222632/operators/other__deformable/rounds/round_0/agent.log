= value[:, level_start:level_end, :, :]  # (N, H*W, M, D)\n        value_level = value_level.reshape(N, H, W, M, D)  # (N, H, W, M, D)\n        \n        # Get sampling locations for this level: (N, Lq, M, P, 2)\n        sampling_loc_level = sampling_locations[:, :, :, level_idx, :, :]\n        \n        # Get attention weights for this level: (N, Lq, M, P)\n        attn_weight_level = attention_weights[:, :, :, level_idx, :]\n        \n        # Process each sample in the batch\n        for n in range(N):\n            for q in range(Lq):\n                for m in range(M):\n                    for p in range(P):\n                        # Get normalized sampling location\n                        loc_h = sampling_loc_level[n, q, m, p, 0].item()  # normalized [0, 1]\n                        loc_w = sampling_loc_level[n, q, m, p, 1].item()  # normalized [0, 1]\n                        \n                        # Convert to absolute coordinates\n                        h_abs = loc_h * (H - 1)\n                        w_abs = loc_w * (W - 1)\n                        \n                        # Boundary check\n                        if h_abs < 0 or h_abs > H - 1 or w_abs < 0 or w_abs > W - 1:\n                            continue\n                        \n                        # Bilinear interpolation\n                        h_low = int(torch.floor(torch.tensor(h_abs)).item())\n                        w_low = int(torch.floor(torch.tensor(w_abs)).item())\n                        h_high = h_low + 1\n                        w_high = w_low + 1\n                        \n                        # Clamp to valid range\n                        h_low = max(0, min(h_low, H - 1))\n                        h_high = max(0, min(h_high, H - 1))\n                        w_low = max(0, min(w_low, W - 1))\n                        w_high = max(0, min(w_high, W - 1))\n                        \n                        # Compute interpolation weights\n                        lh = h_abs -