  63|    sampling_locations = torch.clamp(sampling_locations, 0.1, 0.9)
  64|
  65|    # 创建注意力权重: [batch_size, lq, m, l, k]
  66|    attention_weights = torch.randn(
  67|        n, lq, m, l, k, dtype=torch.float32, device="cuda"
  68|    ).normal_(mean=0.0, std=0.5)
  69|    attention_weights = torch.abs(attention_weights)
  70|    attention_weights = attention_weights / attention_weights.sum(dim=-1, keepdim=True)
  71|
  72|    # 创建输出张量: [batch_size, lq, m*d]
  73|    output_tensor = torch.empty(n, lq, m * d, dtype=torch.float32, device="cuda")
  74|
  75|    # 转换数据类型为MSDeformAttnFunction需要的long类型
  76|    value_spatial_shapes_long = value_spatial_shapes.to(torch.long)
  77|    level_start_index_long = level_start_index.to(torch.long)
  78|
  79|    # CUDA输入：GPU指针列表 (CUDA kernel直接使用原始tensor的内存指针)
  80|    cuda_all_inputs = [
  81|        value,
  82|        value_spatial_shapes,
  83|        level_start_index,
  84|        sampling_locations,
  85|        attention_weights,
  86|        output_tensor,
  87|    ]
  88|
  89|    # PyTorch输入：直接使用正确格式的张量 (给MSDeformAttnFunction使用)
  90|    torch_all_inputs = [
  91|        value,
  92|        value_spatial_shapes_long,
  93|        level_start_index_long,
  94|        sampling_locations,
  95|        attention_weights,
  96|    ]
  97|
  98|    # CUDA输出张量用于结果比较
  99|    cuda_output_tensors = [output_tensor]
  100|
  101|    return cuda_all_inputs, torch_all_inputs, cuda_output_tensors
  102|
  103|
  104|def cuda_output_tensor_transform(cuda_output):
  105|    """
  106|    Args:
  107|        cuda_output: (N_, Lq_, M_*D_) - CUDA kernel output format (已经是目标格式)
  108|
  109|    Returns:
  110|        output: (N_, Lq_, M_*D_) - format aligned with torch_kernel output
  111|    """
  112|    return cuda_output
