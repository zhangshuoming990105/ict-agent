  5|// MaxPool2D kernel optimized for channels_last (NHWC) format
  6|// Each thread computes one output element (one channel at one output position)
  7|__global__ void maxpool2d_kernel(
  8|    const float* __restrict__ input,
  9|    float* __restrict__ output,
  10|    int batch_size,
  11|    int channels,
  12|    int input_H,
  13|    int input_W,
  14|    int kernel_size,
  15|    int stride,
  16|    int output_H,
  17|    int output_W
  18|) {
  19|    // Global thread indices
  20|    int idx = blockIdx.x * blockDim.x + threadIdx.x;
  21|    int total_elements = batch_size * output_H * output_W * channels;
  22|    
  23|    if (idx >= total_elements) return;
  24|    
  25|    // Decode output position (NHWC layout)
  26|    int c = idx % channels;
  27|    int w_out = (idx / channels) % output_W;
  28|    int h_out = (idx / (channels * output_W)) % output_H;
  29|    int n = idx / (channels * output_W * output_H);
  30|    
  31|    // Input starting position for this pooling window
  32|    int h_in_start = h_out * stride;
  33|    int w_in_start = w_out * stride;
  34|    
  35|    // Compute max over the pooling window
  36|    float max_val = -FLT_MAX;
  37|    
  38|    #pragma unroll 4
  39|    for (int kh = 0; kh < kernel_size; kh++) {
  40|        int h_in = h_in_start + kh;
  41|        if (h_in >= input_H) break;
  42|        
  43|        #pragma unroll 4
  44|        for (int kw = 0; kw < kernel_size; kw++) {
  45|            int w_in = w_in_start + kw;
  46|            if (w_in >= input_W) break;
  47|            
  48|            // NHWC indexing: [n, h, w, c]
  49|            int input_idx = ((n * input_H + h_in) * input_W + w_in) * channels + c;
  50|            float val = input[input_idx];
  51|            max_val = fmaxf(max_val, val);
  52|        }
  53|    }
  54|    
  55|    // Write output
  56|    output[idx] = max_val;
