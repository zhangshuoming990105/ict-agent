  """Memory layout conversion utilities for tensor operations"""
  
  import torch
  
  
  def convert_nhwc_to_nchw(tensor: torch.Tensor) -> torch.Tensor:
      """
      Convert tensor from NHWC format to NCHW format.
  
      Args:
          tensor: Input tensor in NHWC format (Batch, Height, Width, Channels)
  
      Returns:
          Tensor in NCHW format (Batch, Channels, Height, Width)
  
      Example:
          >>> x = torch.randn(2, 224, 224, 64)  # NHWC
          >>> y = convert_nhwc_to_nchw(x)       # NCHW
          >>> y.shape
          torch.Size([2, 64, 224, 224])
      """
      if tensor.dim() != 4:
          raise ValueError(
              f"Expected 4D tensor (NHWC), got {tensor.dim()}D tensor with shape {tensor.shape}"
          )
      return tensor.permute(0, 3, 1, 2).contiguous()
  
  
  def convert_nchw_to_nhwc(tensor: torch.Tensor) -> torch.Tensor:
      """
      Convert tensor from NCHW format to NHWC format.
  
      Args:
          tensor: Input tensor in NCHW format (Batch, Channels, Height, Width)
  
      Returns:
          Tensor in NHWC format (Batch, Height, Width, Channels)
      """
      if tensor.dim() != 4:
          raise ValueError(
              f"Expected 4D tensor (NCHW), got {tensor.dim()}D tensor with shape {tensor.shape}"
          )
      return tensor.permute(0, 2, 3, 1).contiguous()
