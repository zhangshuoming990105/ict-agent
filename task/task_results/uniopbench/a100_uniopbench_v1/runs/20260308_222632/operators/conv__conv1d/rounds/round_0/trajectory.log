  1|// CUDA kernel for 1D convolution
  2|// Computes: output[i] = sum(input[i+j] * kernel[j]) for j = 0..kernel_size-1
  3|// where kernel_size = input_size - output_size + 1
  4|
  5|#include <cuda_runtime.h>
  6|
  7|// Optimized kernel using shared memory for the convolution kernel
  8|__global__ void conv1d_kernel(const float* __restrict__ input,
  9|                              const float* __restrict__ kernel,
  10|                              float* __restrict__ output,
  11|                              int input_size,
  12|                              int output_size,
  13|                              int kernel_size) {
  14|    // Shared memory for kernel weights
  15|    extern __shared__ float s_kernel[];
  16|    
  17|    // Load kernel into shared memory cooperatively
  18|    for (int i = threadIdx.x; i < kernel_size; i += blockDim.x) {
  19|        s_kernel[i] = kernel[i];
  20|    }
  21|    __syncthreads();
  22|    
  23|    // Grid-stride loop for output computation
  24|    int idx = blockIdx.x * blockDim.x + threadIdx.x;
  25|    
  26|    for (int out_idx = idx; out_idx < output_size; out_idx += blockDim.x * gridDim.x) {
  27|        float sum = 0.0f;
  28|        
  29|        // Compute convolution at this output position
  30|        #pragma unroll 4
  31|        for (int k = 0; k < kernel_size; k++) {
  32|            sum += input[out_idx + k] * s_kernel[k];
  33|        }
  34|        
  35|        output[out_idx] = sum;
  36|    }
  37|}
