// cuda_/kernel.cu
/**
 * Square operator: output = input^2
 *
 * Element-wise square on a contiguous 1D buffer.
 */

#include <assert.h>

__global__ void _square_kernel_impl(
    const float* __restrict__ input,
    float* __restrict__ output,
    int size
) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx < size) {
        float v = input[idx];
        output[idx] = v * v;
    }
}

