t)[tid * 2] = data;\n        } else {\n            float data = input1[src_offset];\n            output[dst_offset] = data;\n        }\n        \n        // Destination offset in output (second C channels)\n        const int dst_offset2 = batch_idx * output_channel_spatial_size + \n                                (C + channel_idx) * spatial_size + spatial_idx;\n        \n        // Vectorized load and store for input2 -> output\n        if (VEC_SIZE == 4) {\n            float4 data = reinterpret_cast<const float4*>(input2)[tid];\n            reinterpret_cast<float4*>(output)[tid * 2 + 1] = data;\n        } else if (VEC_SIZE == 2) {\n            float2 data = reinterpret_cast<const float2*>(input2)[tid];\n            reinterpret_cast<float2*>(output)[tid * 2 + 1] = data;\n        } else {\n            float data = input2[src_offset];\n            output[dst_offset2] = data;\n        }\n    }\n    \n    // Handle remaining elements\n    const int remainder_start = vec_elements * VEC_SIZE;\n    const int remainder_tid = tid - vec_elements;\n    \n    if (remainder_tid >= 0 && remainder_tid < (total_elements - remainder_start)) {\n        const int linear_idx = remainder_start + remainder_tid;\n        const int batch_idx = linear_idx / channel_spatial_size;\n        const int within_batch = linear_idx % channel_spatial_size;\n        \n        const int channel_idx = within_batch / spatial_size;\n        const int spatial_idx = within_batch % spatial_size;\n        \n        const int src_offset = linear_idx;\n        const int dst_offset1 = batch_idx * output_channel_spatial_size + \n                                channel_idx * spatial_size + spatial_idx;\n        const int dst_offset2 = batch_idx * output_channel_spatial_size + \n                                (C + channel_idx) * spatial_size + spatial_idx;\n        \n        output[dst_offset1] = input1[src_offset];\n        output[dst_offset2] = input2[src_offset];\n    }\n}\n\n// Simple kernel without vectorization for comparison\n__global__ void concat_kernel_simple(\n    const float* __restrict__ input1,\n    const float* __restrict__ input2,\n    float* __restrict__ output,\n    int N, int C, int H, int W)\n{\n    const int spatial_size = H * W;\n    const int idx = blockIdx.x * blockDim.x + threadIdx.x;\n    const int total_elements = N * C * spatial_size;\n    \n    if (idx < total_elements) {\n        const int channel_spatial_size = C * spatial_size;\n        const int batch_idx = idx / channel_spatial_size;\n        const int within_batch = idx % channel_spatial_size;\n        \n        const int channel_idx = within_batch / spatial_size;\n        const int spatial_idx = within_batch % spatial_size;\n        \n        // Output layout: (N, 2*C, H, W)\n        const int output_channel_spatial_size = 2 * C * spatial_size;\n        \n        // Copy from input1 to first C channels of output\n        const int dst_offset1 = batch_idx * output_channel_spatial_size + \n                                channel_idx * spatial_size + spatial_idx;\n        output[dst_offset1] = input1[idx];\n        \n        // Copy from input2 to second C channels of output\n        const int dst_offset2 = batch_idx * output_channel_spatial_size + \n                                (C + channel_idx) * spatial_size + spatial_idx;\n        output[dst_offset2] = input2[idx];\n    }\n}\n\nextern \"C\" void concat_kernel(\n    const float* input1,\n    const float* input2,\n    float* output,\n    int N, int C, int H, int W)\n{\n    const int spatial_size = H * W;\n    const int total_elements = N * C * spatial_size;\n    \n    const int block_size = 256;\n    const int num_blocks = (total_elements + block_size - 1) / block_size;\n    \n    // Use simple kernel for better correctness\n    concat_kernel_simple<<<num_blocks, block_size>>>(\n        input1, input2, output, N, C, H, W);\n}\n","mode":"overwrite","path":"cuda_/kernel.cu"})
