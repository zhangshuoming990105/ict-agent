command=python -c "
import torch
import ctypes
import sys
import os

# Load the CUDA library
lib = ctypes.CDLL('./cuda_/lib_cuda_kernel.so')
lib.cuda_kernel.argtypes = [
    ctypes.c_void_p,  # input
    ctypes.c_void_p,  # output
    ctypes.c_int,     # batch_size
    ctypes.c_int,     # channels
    ctypes.c_int,     # input_H
    ctypes.c_int,     # kernel_size
    ctypes.c_int,     # stride
]

# Simple test: 1x1x5x5 input, 5x5 kernel, stride 1
batch, channels, H, W = 1, 1, 5, 5
kernel_size, stride = 5, 1
output_H = (H - kernel_size) // stride + 1
output_W = (W - kernel_size) // stride + 1

print(f'Input shape: ({batch}, {channels}, {H}, {W})')
print(f'Output shape should be: ({batch}, {channels}, {output_H}, {output_W})')

# Create input - all ones
x = torch.ones(batch, channels, H, W, device='cuda', dtype=torch.float32).to(memory_format=torch.channels_last)
y = torch.zeros(batch, channels, output_H, output_W, device='cuda', dtype=torch.float32).to(memory_format=torch.channels_last)

print('Input data ptr:', x.data_ptr())
print('Output data ptr:', y.data_ptr())
print('Input size:', x.numel())
print('Output size:', y.numel())

# Call kernel
lib.cuda_kernel(
    x.data_ptr(),
    y.data_ptr(),
    batch,
    channels,
    H,
    kernel_size,
    stride
)

torch.cuda.synchronize()

print('Output value:', y.item())
print('Expected (average of 25 ones):', 1.0)
"
