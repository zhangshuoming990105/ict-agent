import torch
import ctypes

# Load the CUDA library
lib = ctypes.CDLL('./cuda_/lib_cuda_kernel.so')
lib.cuda_kernel.argtypes = [
    ctypes.c_void_p, ctypes.c_void_p, ctypes.c_int, ctypes.c_int, ctypes.c_int, ctypes.c_int, ctypes.c_int
]

# Test with actual dimensions
batch, channels, H, W = 4, 128, 56, 56
kernel_size, stride = 5, 2
output_H = (H - kernel_size) // stride + 1
output_W = (W - kernel_size) // stride + 1

print(f'Input: ({batch}, {channels}, {H}, {W})')
print(f'Output: ({batch}, {channels}, {output_H}, {output_W})')

# Create test data
torch.manual_seed(42)
x = torch.randn(batch, channels, H, W, device='cuda', dtype=torch.float32).to(memory_format=torch.channels_last)
y_cuda = torch.zeros(batch, channels, output_H, output_W, device='cuda', dtype=torch.float32).to(memory_format=torch.channels_last)
y_torch = torch.nn.functional.avg_pool2d(x, kernel_size=kernel_size, stride=stride)

# Call kernel
lib.cuda_kernel(x.data_ptr(), y_cuda.data_ptr(), batch, channels, H, kernel_size, stride)
torch.cuda.synchronize()

# Compare first few values
print('\\nFirst 5 CUDA outputs:', y_cuda.flatten()[:5])
print('First 5 Torch outputs:', y_torch.flatten()[:5])
print('\\nMax diff:', (y_cuda - y_torch).abs().max().item())
print('Mean diff:', (y_cuda - y_torch).abs().mean().item())
"
