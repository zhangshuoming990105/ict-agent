      x = torch.randn(shape, dtype=torch.float32, device='cuda')
      
      # Compute reference
      ref = torch.amin(x, dim=0)
      
      # Flatten for CUDA kernel
      x_flat = x.reshape(rows, inner)
      output = torch.empty(inner, dtype=torch.float32, device='cuda')
      
      # Call CUDA kernel
      lib.cuda_kernel(
