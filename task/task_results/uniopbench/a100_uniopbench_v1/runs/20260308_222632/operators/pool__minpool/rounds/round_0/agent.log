import torch
import sys
import os
from test import testcase, MinPoolParams
from optest import CUDABackend, TestConfig
from optest.execution.runner import TestRunner
from optest.tools.layout import convert_nhwc_to_nchw

params = MinPoolParams()
backend = CUDABackend()
config = TestConfig(enable_perf=False)

# Load the backend
testcase_dir = '.'
backend.load(testcase_dir, testcase, params)

# Generate test data
torch.manual_seed(42)
input_nhwc = torch.randn(params.batch_size, params.input_height, params.input_width, params.channels, device='cuda')
print('Input NHWC:', input_nhwc.shape)

