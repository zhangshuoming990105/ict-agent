ssuming square input (width = height)\n    int input_W = input_H;\n    \n    // Calculate output dimensions\n    int output_H = (input_H - kernel_size) / stride + 1;\n    int output_W = (input_W - kernel_size) / stride + 1;\n    \n    // Total output elements\n    int total_elements = batch_size * output_H * output_W * channels;\n    \n    // Launch configuration optimized for A100\n    int threads = 256;\n    int blocks = (total_elements + threads - 1) / threads;\n    \n    maxpool2d_kernel<<<blocks, threads>>>(\n        input,\n        output,\n        batch_size,\n        channels,\n        input_H,\n        input_W,\n        kernel_size,\n        stride,\n        output_H,\n        output_W\n    );\n}\n"})
