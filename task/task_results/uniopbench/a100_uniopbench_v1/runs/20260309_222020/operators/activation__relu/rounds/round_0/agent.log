// Helper: grid-stride loop for robustness across different sizes
template <typename T>
__device__ __forceinline__ T relu_func(T x) {
    return x > T(0) ? x : T(0);
}

// ---------------------------------------------------------------------------
// FP32 implementations
// ---------------------------------------------------------------------------

// op_type 0: FP32 scalar
__global__ void relu_f32_scalar(const float* __restrict__ input,
                                 float* __restrict__ output,
                                 int N) {
    const int stride = blockDim.x * gridDim.x;
    for (int idx = blockIdx.x * blockDim.x + threadIdx.x; idx < N; idx += stride) {
        output[idx] = relu_func(input[idx]);
    }
}

// op_type 1: FP32x4 vectorized
__global__ void relu_f32x4(const float* __restrict__ input,
                            float* __restrict__ output,
                            int N) {
    const int stride = blockDim.x * gridDim.x;
    const int vec_N = N / 4;
    
    for (int idx = blockIdx.x * blockDim.x + threadIdx.x; idx < vec_N; idx += stride) {
        // Load 4 floats at once
        float4 val = reinterpret_cast<const float4*>(input)[idx];
        val.x = relu_func(val.x);
        val.y = relu_func(val.y);
        val.z = relu_func(val.z);
        val.w = relu_func(val.w);
        reinterpret_cast<float4*>(output)[idx] = val;
    }
    
    // Handle remaining elements
    int remaining_start = vec_N * 4;
    for (int idx = remaining_start + blockIdx.x * blockDim.x + threadIdx.x; idx < N; idx += stride) {
        output[idx] = relu_func(input[idx]);
    }
}

