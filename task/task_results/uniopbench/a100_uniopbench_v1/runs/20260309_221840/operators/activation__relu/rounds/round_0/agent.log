// Scalar f32 ReLU kernel
__global__ void relu_f32_scalar_kernel(const float* input, float* output, int N) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int stride = blockDim.x * gridDim.x;
    
    for (int i = idx; i < N; i += stride) {
        float val = input[i];
        output[i] = val > 0.0f ? val : 0.0f;
    }
}

// Vectorized f32x4 ReLU kernel
__global__ void relu_f32x4_kernel(const float* input, float* output, int N) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int stride = blockDim.x * gridDim.x;
    int n4 = N / 4;
    
    for (int i = idx; i < n4; i += stride) {
        float4 val = reinterpret_cast<const float4*>(input)[i];
        float4 result;
        result.x = val.x > 0.0f ? val.x : 0.0f;
        result.y = val.y > 0.0f ? val.y : 0.0f;
        result.z = val.z > 0.0f ? val.z : 0.0f;
        result.w = val.w > 0.0f ? val.w : 0.0f;
        reinterpret_cast<float4*>(output)[i] = result;
    }
    
    // Handle remaining elements
    int base = n4 * 4;
    for (int i = base + idx; i < N; i += stride) {
        float val = input[i];
        output[i] = val > 0.0f ? val : 0.0f;
    }
}

// Scalar f16 ReLU kernel
__global__ void relu_f16_scalar_kernel(const half* input, half* output, int N) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int stride = blockDim.x * gridDim.x;
    
    for (int i = idx; i < N; i += stride) {
        half val = input[i];
        output[i] = __hgt(val, __float2half(0.0f)) ? val : __float2half(0.0f);
    }
}

// Vectorized f16x2 ReLU kernel
__global__ void relu_f16x2_kernel(const half* input, half* output, int N) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int stride = blockDim.x * gridDim.x;
    int n2 = N / 2;
    
    for (int i = idx; i < n2; i += stride) {
        half2 val = reinterpret_cast<const half2*>(input)[i];
        half2 zero = __float2half2_rn(0.0f);
        half2 result;
        // ReLU for each half in half2
        result.x = __hgt(val.x, zero.x) ? val.x : zero.x;
        result.y = __hgt(val.y, zero.y) ? val.y : zero.y;
        reinterpret_cast<half2*>(output)[i] = result;
    }
    
    // Handle remaining elements
    int base = n2 * 2;
    for (int i = base + idx; i < N; i += stride) {
        half val = input[i];
        output[i] = __hgt(val, __float2half(0.0f)) ? val : __float2half(0.0f);
    }
}

// Vectorized f16x8 unpack ReLU kernel
__global__ void relu_f16x8_unpack_kernel(const half* input, half* output, int N) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int stride = blockDim.x * gridDim.x;
    int n8 = N / 8;
    
    for (int i = idx; i < n8; i += stride) {
        // Load 8 half values (128 bits)
        uint4 vec = reinterpret_cast<const uint4*>(input)[i];
        half h[8];
        // Unpack
        half* h_ptr = reinterpret_cast<half*>(&vec);
        #pragma unroll
        for (int j = 0; j < 8; ++j) {
            h[j] = __hgt(h_ptr[j], __float2half(0.0f)) ? h_ptr[j] : __float2half(0.0f);
        }
        reinterpret_cast<uint4*>(output)[i] = *reinterpret_cast<uint4*>(h);
    }
    
    // Handle remaining elements
    int base = n8 * 8;
    for (int i = base + idx; i < N; i += stride) {
        half val = input[i];
        output[i] = __hgt(val, __float2half(0.0f)) ? val : __float2half(0.0f);
    }
}

// Vectorized f16x8 pack ReLU kernel (using float4 for 128-bit aligned access)
__global__ void relu_f16x8_pack_kernel(const half* input, half* output, int N) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int stride = blockDim.x * gridDim.x;
    int n8 = N / 8;
    
    half zero = __float2half(0.0f);
    
    for (int i = idx; i < n8; i += stride) {
        // Load 8 half values using float4 (128-bit access)
        float4 vec = reinterpret_cast<const float4*>(input)[i];
        half* h = reinterpret_cast<half*>(&vec);
        
        // Process all 8 elements
        uint2 result;
        half* out_h = reinterpret_cast<half*>(&result);
        #pragma unroll
        for (int j = 0; j < 8; ++j) {
            out_h[j] = __hgt(h[j], zero) ? h[j] : zero;
        }
        reinterpret_cast<float4*>(output)[i] = *reinterpret_cast<float4*>(&result);
    }
    
    // Handle remaining elements
    int base = n8 * 8;
    for (int i = base + idx; i < N; i += stride) {
        half val = input[i];
        output[i] = __hgt(val, zero) ? val : zero;
    }
}

