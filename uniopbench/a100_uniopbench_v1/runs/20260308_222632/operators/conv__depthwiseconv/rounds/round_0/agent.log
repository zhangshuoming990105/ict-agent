import torch
import sys
sys.path.insert(0, '.')

# Simulate the exact same input preparation
input_size = 128
kernel_size = 3
channels = 128

input_hwc = torch.randn(input_size, input_size, channels)
kernel_hwc = torch.randn(kernel_size, kernel_size, channels)

# Convert as in get_data.py
input_nchw = input_hwc.permute(2, 0, 1).unsqueeze(0).contiguous()
kernel_nchw = kernel_hwc.permute(2, 0, 1).unsqueeze(1).contiguous()

print('Input shape:', input_nchw.shape)
print('Kernel shape:', kernel_nchw.shape)

# Try the reference implementation
try:
    output = torch.nn.functional.conv2d(
        input_nchw,
        kernel_nchw,
        groups=input_nchw.shape[1],
        padding=0,
    )
    print('Success! Output shape:', output.shape)
except Exception as e:
    print('Error:', e)
