6|def torch_kernel(x: torch.Tensor) -> torch.Tensor:
7|    """Causal Softmax: Apply causal mask then softmax.
8|    
9|    Causal mask ensures that position i can only see positions <= i.
10|    This is typically used in autoregressive models like transformers.
11|    
12|    Args:
13|        x: Input tensor of shape (batch, seq_len) or (batch, num_heads, seq_len)
14|        
15|    Returns:
16|        Output tensor with causal softmax applied along the last dimension
17|    """
18|    # Convert to float32 for stable computation
19|    dtype = x.dtype
20|    x_float = x.to(torch.float32)
21|    
22|    # Create causal mask: lower triangular matrix
23|    # For each row i, positions > i should be masked (set to -inf)
24|    seq_len = x_float.shape[-1]
25|    
26|    # Causal Softmax implementation matching CUDA kernel logic:
27|    # For each position i in a sequence, normalize over valid positions [0, i+1).
28|    # This means for output[i], the denominator is sum(exp(x[0]...x[i])).
29|    # This is different from standard causal attention where we have a query i attending to keys j<=i.
30|    # Here, we treat the input as a single sequence of values.
31|    #
32|    # Logic:
33|    # 1. Compute exp(x - max)
34|    # 2. Compute cumulative sum of exp values (cumsum)
35|    # 3. Divide exp values by their corresponding cumsum value
36|    
37|    # Subtract max for stability
38|    x_max = x_float.max(dim=-1, keepdim=True)[0]
39|    exp_x = torch.exp(x_float - x_max)
40|    
41|    # Compute cumulative sum along the last dimension
42|    # cumsum[i] = sum(exp_x[0]...exp_x[i])
43|    cumsum_exp = torch.cumsum(exp_x, dim=-1)
44|    
45|    # Normalize
46|    # result[i] = exp_x[i] / cumsum_exp[i]
47|    result = exp_x / cumsum_exp
48|    
49|    # Convert back to original dtype
50|    return result.to(dtype)
