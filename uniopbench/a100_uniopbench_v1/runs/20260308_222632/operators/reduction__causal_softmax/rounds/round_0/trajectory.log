  1|/*
  2| * CUDA kernel for Causal Softmax operator
  3| *
  4| * Causal Softmax applies softmax with a causal mask:
  5| * For each position i in a sequence, normalize over positions [0, i].
  6| * output[i] = exp(x[i] - max) / sum(exp(x[j] - max) for j in [0, i])
  7| *
  8| * This implementation:
  9| * - Assigns one warp (32 threads) per sequence for coalesced memory access
  10| * - Uses warp-level reductions for max and sum computation
  11| * - Processes sequences in a grid-stride loop for flexibility
  12| */
  13|
  14|#include <cuda_runtime.h>
  15|#include <math.h>
  16|
  17|// Warp size constant
  18|#define WARP_SIZE 32
  19|
  20|// Warp-level reduction helpers using __shfl_down_sync
  21|__device__ __forceinline__ float warp_reduce_max(float val) {
  22|    #pragma unroll
  23|    for (int offset = 16; offset > 0; offset >>= 1) {
  24|        val = fmaxf(val, __shfl_down_sync(0xffffffff, val, offset));
  25|    }
  26|    return val;
  27|}
  28|
  29|__device__ __forceinline__ float warp_reduce_sum(float val) {
  30|    #pragma unroll
  31|    for (int offset = 16; offset > 0; offset >>= 1) {
  32|        val += __shfl_down_sync(0xffffffff, val, offset);
  33|    }
  34|    return val;
  35|}
  36|
  37|/*
  38| * Causal Softmax CUDA kernel
  39| *
  40| * Each warp processes one sequence row. For position i, we compute:
  41| * 1. max_val = max(x[0], ..., x[i])
  42| * 2. exp_sum = sum(exp(x[j] - max_val) for j in [0, i])
  43| * 3. output[i] = exp(x[i] - max_val) / exp_sum
  44| *
  45| * Grid: (num_warps_needed, 1, 1) where num_warps_needed = ceil(batch_size / warps_per_block)
  46| * Block: (WARP_SIZE, warps_per_block, 1)
  47| */
  48|__global__ void causal_softmax_kernel_float(
  49|    const float* __restrict__ input,
  50|    float* __restrict__ output,
  51|    const int batch_size,
  52|    const int seq_len
  53|) {
  54|    // One warp per sequence
  55|    const int warp_id = blockIdx.x * blockDim.y + threadIdx.y;
  56|    const int lane_id = threadIdx.x;
  57|    
  58|    if (warp_id >= batch_size) return;
  59|    
  60|    const float* seq_input = input + warp_id * seq_len;
  61|    float* seq_output = output + warp_id * seq_len;
  62|    
  63|    // Process each position i in the sequence
  64|    for (int i = 0; i < seq_len; i++) {
  65|        // Step 1: Compute max over [0, i]
  66|        float local_max = -INFINITY;
  67|        for (int j = lane_id; j <= i; j += WARP_SIZE) {
  68|            local_max = fmaxf(local_max, seq_input[j]);
  69|        }
  70|        float max_val = warp_reduce_max(local_max);
  71|        max_val = __shfl_sync(0xffffffff, max_val, 0);  // Broadcast from lane 0
  72|        
  73|        // Step 2: Compute sum(exp(x[j] - max_val)) for j in [0, i]
  74|        float local_sum = 0.0f;
  75|        for (int j = lane_id; j <= i; j += WARP_SIZE) {
  76|            local_sum += expf(seq_input[j] - max_val);
  77|        }
  78|        float exp_sum = warp_reduce_sum(local_sum);
  79|        exp_sum = __shfl_sync(0xffffffff, exp_sum, 0);  // Broadcast from lane 0
  80|        
  81|        // Step 3: Compute output[i] = exp(x[i] - max_val) / exp_sum
  82|        if (lane_id == 0) {
  83|            float exp_val = expf(seq_input[i] - max_val);
  84|            seq_output[i] = exp_val / exp_sum;
  85|        }
  86|    }
  87|}
  88|
  89|/*
  90| * Host function to launch the causal softmax kernel
  91| *
  92| * This is the C interface expected by the Python wrapper.
  93| * The function must be named "cuda_kernel" to match the framework's expectations.
  94| */
  95|extern "C" void cuda_kernel(
  96|    const float* input,
  97|    float* output,
  98|    int batch_size,
  99|    int seq_len
  100|) {
  101|    // Configure kernel launch parameters
  102|    // Use multiple warps per block for better occupancy
  103|    const int warps_per_block = 4;  // Tune this for best performance
  104|    const int num_blocks = (batch_size + warps_per_block - 1) / warps_per_block;
  105|    
  106|    dim3 block_dim(WARP_SIZE, warps_per_block, 1);
  107|    dim3 grid_dim(num_blocks, 1, 1);
  108|    
  109|    // Launch kernel
  110|    causal_softmax_kernel_float<<<grid_dim, block_dim>>>(
  111|        input,
  112|        output,
  113|        batch_size,
  114|        seq_len
  115|    );
