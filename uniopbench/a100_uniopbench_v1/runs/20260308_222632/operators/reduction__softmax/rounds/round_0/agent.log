def load_cuda_kernel(
    testcase_root_dir, argtypes, restype=None, force_compile=False, arch="sm_89"
):
    """加载编译好的CUDA内核

    Args:
        testcase_root_dir: 测试用例根目录
        argtypes: 函数参数类型列表(ctypes类型)
        restype: 函数返回类型(ctypes类型)
        force_compile: 强制重新编译
        arch: CUDA架构

    Returns:
        可调用的CUDA内核函数

    Raises:
        RuntimeError: 编译或加载失败
    """
    # 尝试编译kernel
    lib_path = compile_cuda_kernel(
        testcase_root_dir, "kernel", force_compile=force_compile, arch=arch
    )
    if not lib_path:
        raise RuntimeError("CUDA kernel compilation failed")

    lib = ctypes.CDLL(lib_path)

    # 设置函数签名
    lib.cuda_kernel.argtypes = argtypes
    lib.cuda_kernel.restype = restype

    return lib.cuda_kernel
