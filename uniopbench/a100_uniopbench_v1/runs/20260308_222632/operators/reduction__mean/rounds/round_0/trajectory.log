              ctypes.c_void_p(x.data_ptr()),
              ctypes.c_void_p(cuda_out.data_ptr()),
              rows, inner
          )
      torch.cuda.synchronize()
      
      # Benchmark
      start = time.perf_counter()
      for _ in range(100):
          lib.cuda_kernel(
              ctypes.c_void_p(x.data_ptr()),
              ctypes.c_void_p(cuda_out.data_ptr()),
              rows, inner
          )
      torch.cuda.synchronize()
      end = time.perf_counter()
      
