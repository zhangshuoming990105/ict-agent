import torch
import sys
import os
sys.path.insert(0, '.')
from test import SigmoidParams
from torch_.ref import torch_kernel
import ctypes

# Load CUDA library
lib = ctypes.CDLL('./cuda_/lib_cuda_kernel.so')
lib.cuda_kernel.argtypes = [ctypes.c_void_p, ctypes.c_void_p, ctypes.c_int, ctypes.c_int]

# Test case: float32, [2048, 2048], op_levels=2
params = SigmoidParams(shape=(2048, 2048), dtype=torch.float32, op_levels=2)
print(f'Testing: dtype={params.dtype}, shape={params.shape}, op_levels={params.op_levels}, op_type={params.final_op_type}')

torch.manual_seed(42)
input_tensor = torch.randn(params.shape, dtype=params.dtype, device='cuda')
output_tensor = torch.empty_like(input_tensor)

# Run CUDA kernel
lib.cuda_kernel(
    ctypes.c_void_p(input_tensor.data_ptr()),
    ctypes.c_void_p(output_tensor.data_ptr()),
    params.total_elements,
    params.final_op_type
)
torch.cuda.synchronize()

# Run PyTorch reference
ref_output = torch_kernel(input_tensor)

# Compare
max_err = (output_tensor - ref_output).abs().max().item()
mean_err = (output_tensor - ref_output).abs().mean().item()
print(f'Max error: {max_err}')
print(f'Mean error: {mean_err}')
print(f'Match: {torch.allclose(output_tensor, ref_output, atol=1e-3, rtol=1e-3)}')
" 2>&1
