  21|    // Grid-stride loop pattern for better occupancy
  22|    // Each thread computes one output element
  23|    const int total_output = batch_size * output_H * output_W * channels;
  24|    
  25|    for (int idx = blockIdx.x * blockDim.x + threadIdx.x;
  26|         idx < total_output;
  27|         idx += blockDim.x * gridDim.x) {
