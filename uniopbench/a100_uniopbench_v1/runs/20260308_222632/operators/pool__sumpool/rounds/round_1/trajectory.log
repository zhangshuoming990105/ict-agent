  31|        const int w_out = (idx / channels) % output_W;
  32|        const int h_out = (idx / channels / output_W) % output_H;
  33|        const int n = idx / (channels * output_W * output_H);
  34|        
  35|        // Calculate input window position
  36|        const int h_in_start = h_out * stride;
  37|        const int w_in_start = w_out * stride;
  38|        
